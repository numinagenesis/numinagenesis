# NUMINA Soul Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Ethereum private key (0x-prefixed) of the wallet that funds Arweave uploads.
# The wallet must have ETH loaded into Irys node2 (https://node2.irys.xyz).
# Fund via: https://irys.xyz/docs/uploading/funding
IRYS_PRIVATE_KEY=0x_your_private_key_here
