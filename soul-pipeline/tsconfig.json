{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true,
    "outDir":           "dist",
    "rootDir":          "."
  },
  "include": ["*.ts"]
}
